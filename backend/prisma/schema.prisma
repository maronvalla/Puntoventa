generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id        String   @id @default(cuid())
  name      String
  address   String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  inventory        BusinessProduct[]
  sales            Sale[]
  purchases        Purchase[]
  stockAdjustments StockAdjustment[]

  @@map("businesses")
}

model User {
  id         String    @id @default(cuid())
  username   String    @unique
  email      String    @unique
  password   String
  name       String
  role       Role      @default(CASHIER)
  active     Boolean   @default(true)
  business   Business? @relation(fields: [businessId], references: [id])
  businessId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sales            Sale[]
  purchases        Purchase[]
  stockAdjustments StockAdjustment[]

  @@index([businessId])
  @@map("users")
}

enum Role {
  OWNER
  CASHIER
}

model Product {
  id        String   @id @default(cuid())
  name      String
  barcode   String?
  code      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventories BusinessProduct[]

  @@map("products")
}

model BusinessProduct {
  id            String   @id @default(cuid())
  business      Business @relation(fields: [businessId], references: [id])
  businessId    String
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  price         Decimal  @db.Decimal(12, 2)
  costPrice     Decimal  @db.Decimal(12, 2)
  stock         Int      @default(0)
  criticalStock Int      @default(5)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  saleItems        SaleItem[]
  purchaseItems    PurchaseItem[]
  stockAdjustments StockAdjustment[]

  @@unique([businessId, productId])
  @@index([businessId, active])
  @@map("business_products")
}

model Sale {
  id             String        @id @default(cuid())
  business       Business      @relation(fields: [businessId], references: [id])
  businessId     String
  seller         User          @relation(fields: [sellerId], references: [id])
  sellerId       String
  sellerName     String
  dayKey         String
  total          Decimal       @db.Decimal(12, 2)
  paymentMethod  PaymentMethod @default(CASH)
  cashAmount     Decimal       @default(0) @db.Decimal(12, 2)
  transferAmount Decimal       @default(0) @db.Decimal(12, 2)
  status         SaleStatus    @default(ACTIVE)
  voidReason     String?
  voidedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items SaleItem[]

  @@index([businessId, dayKey])
  @@index([businessId, sellerId])
  @@index([status])
  @@map("sales")
}

enum PaymentMethod {
  CASH
  TRANSFER
  MIXED
}

enum SaleStatus {
  ACTIVE
  VOIDED
}

model SaleItem {
  id                String          @id @default(cuid())
  sale              Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId            String
  businessProduct   BusinessProduct @relation(fields: [businessProductId], references: [id])
  businessProductId String
  name              String
  qty               Int
  unitPrice         Decimal         @db.Decimal(12, 2)
  itemCostPrice     Decimal         @db.Decimal(12, 2)
  barcode           String?
  code              String?
  lineTotal         Decimal         @db.Decimal(12, 2)

  @@map("sale_items")
}

model Purchase {
  id         String   @id @default(cuid())
  business   Business @relation(fields: [businessId], references: [id])
  businessId String
  admin      User     @relation(fields: [adminId], references: [id])
  adminId    String
  adminName  String
  dayKey     String
  totalCost  Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items PurchaseItem[]

  @@index([businessId, dayKey])
  @@map("purchases")
}

model PurchaseItem {
  id                String          @id @default(cuid())
  purchase          Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId        String
  businessProduct   BusinessProduct @relation(fields: [businessProductId], references: [id])
  businessProductId String
  name              String
  qty               Int
  costPrice         Decimal         @db.Decimal(12, 2)

  @@map("purchase_items")
}

model StockAdjustment {
  id                String          @id @default(cuid())
  business          Business        @relation(fields: [businessId], references: [id])
  businessId        String
  businessProduct   BusinessProduct @relation(fields: [businessProductId], references: [id])
  businessProductId String
  delta             Int
  reason            String
  admin             User            @relation(fields: [adminId], references: [id])
  adminId           String
  adminName         String
  createdAt         DateTime        @default(now())

  @@index([businessId])
  @@map("stock_adjustments")
}
